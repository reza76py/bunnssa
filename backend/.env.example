# Django settings profile
DJANGO_SETTINGS_MODULE=backend.settings.production

# Core app security
SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=False

# Comma-separated host/origin values
ALLOWED_HOSTS=staffallocation.rezteche.com,www.staffallocation.rezteche.com
CSRF_TRUSTED_ORIGINS=https://staffallocation.rezteche.com,https://www.staffallocation.rezteche.com
CORS_ALLOWED_ORIGINS=https://staffallocation.rezteche.com,https://www.staffallocation.rezteche.com

# MySQL connection
DB_ENGINE=django.db.backends.mysql
DB_NAME=bunnings_ssa
DB_USER=bunnings_user
DB_PASSWORD=replace-with-a-strong-database-password
DB_HOST=db
DB_PORT=3306

# Fallback SMTP settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=your-16-char-gmail-app-password

# Production HTTP security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Static/media inside container filesystem
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
