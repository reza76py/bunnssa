# ------------------------------
# Bunnings SSA production config
# Copy this file to .env on your server and replace placeholder values.
# This single .env is used by docker-compose.prod.yml and Django.
# ------------------------------

# --- Django runtime ---
DJANGO_SETTINGS_MODULE=backend.settings.production
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False

# Comma-separated values (no spaces)
ALLOWED_HOSTS=staffallocation.rezteche.com,www.staffallocation.rezteche.com
CSRF_TRUSTED_ORIGINS=https://staffallocation.rezteche.com,https://www.staffallocation.rezteche.com
CORS_ALLOWED_ORIGINS=https://staffallocation.rezteche.com,https://www.staffallocation.rezteche.com

# --- Database (MySQL container + Django connection) ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=bunnings_ssa
DB_USER=bunnings_user
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=db
DB_PORT=3306

# --- Email (fallback SMTP values; per-user SMTP remains supported in-app) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=your-16-char-gmail-app-password

# --- Security hardening ---
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# --- Static / media paths inside backend container ---
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# --- React build-time API endpoint ---
# Used when building the frontend production image.
REACT_APP_API_URL=https://staffallocation.rezteche.com/api
